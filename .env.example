# Supabase (proyecto en São Paulo). Keys nuevas: sb_publishable_... y sb_secret_...
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Solo servidor: seed, rls:check y operaciones admin. Jamás en el cliente.
SUPABASE_SECRET_KEY=sb_secret_...

# URL pública de la app (para armar los links de invitación).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: envío real de emails de invitación (fase siguiente).
# Sin esta variable, el link de invitación se loguea en consola y se muestra para copiar.
# RESEND_API_KEY=re_...

# Demo pública: muestra el botón "Ver demo de prueba" en el login y lo deja
# entrar con estas credenciales. Setear SOLO en producción (nunca en dev).
# NEXT_PUBLIC_DEMO=true
# DEMO_EMAIL=juanse@sobres.local
# DEMO_PASSWORD=coghlan-juanse-2026

# Google (login + conexión Gmail). Guía completa en docs/GMAIL.md.
# NEXT_PUBLIC_GOOGLE=true muestra "Continuar con Google" y la card de Gmail;
# recién activarla cuando el proyecto de Google Cloud + el provider de
# Supabase estén configurados. CLIENT_ID/SECRET: los MISMOS del provider
# (los usa el server para refrescar el access token de Gmail).
# NEXT_PUBLIC_GOOGLE=true
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# Cifrado de los refresh tokens de Gmail (AES-256-GCM). Generar con:
# openssl rand -base64 32
# GMAIL_TOKEN_KEY=...
